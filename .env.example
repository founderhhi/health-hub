DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_SSL=true
JWT_SECRET=demo_secret
DAILY_API_KEY=your_daily_key
DAILY_FALLBACK_ROOM=https://healthhub.daily.co/demo

# Ollama base URL for local AI chat inference (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama medical model tag for HealthHub triage (default fallback: meditron:7b)
OLLAMA_MODEL=meditron:7b
