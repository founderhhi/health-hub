DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_SSL=true
JWT_SECRET=demo_secret
DAILY_API_KEY=your_daily_key
DAILY_FALLBACK_ROOM=https://healthhub.daily.co/demo

# Anthropic API key for HealthHub AI triage chat (required)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: override the Claude model used for triage (default: claude-opus-4-6)
CLAUDE_MODEL=claude-opus-4-6

# Stripe keys (required for billing/payments)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
